<Window x:Class="SnippetLauncher.App.Views.SearchPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SnippetLauncher.App.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:SearchPopupViewModel}"
        Title="Snippet Launcher"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Width="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="ResultItem" TargetType="Border">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <!-- Acrylic-like glass effect via blur + semi-transparent background -->
    <Border CornerRadius="12"
            Background="#E8202020"
            BorderBrush="#44FFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.6" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Search box row -->
            <Grid Grid.Row="0" Margin="12,12,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Search icon -->
                <TextBlock Grid.Column="0" Text="⌕"
                           FontSize="20" Foreground="#99FFFFFF"
                           VerticalAlignment="Center" Margin="4,0,8,0"/>

                <TextBox x:Name="SearchBox"
                         Grid.Column="1"
                         Text="{Binding QueryText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="18"
                         Foreground="White"
                         CaretBrush="White"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0,6"
                         VerticalAlignment="Center"
                         PreviewKeyDown="SearchBox_KeyDown">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Resources>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </Style.Resources>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <ScrollViewer x:Name="PART_ContentHost" Focusable="False"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>

            <!-- Separator -->
            <Border Grid.Row="0" Height="1" Background="#33FFFFFF"
                    VerticalAlignment="Bottom" Margin="12,50,12,0"/>

            <!-- Results list -->
            <ItemsControl Grid.Row="1"
                          ItemsSource="{Binding Results}"
                          Margin="6,6,6,2"
                          MaxHeight="380"
                          Focusable="False">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:SearchResultItem}">
                        <Border Padding="10,7" CornerRadius="8" Margin="0,1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Background" Value="#334D9FFF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="14" Foreground="White"
                                               FontWeight="Medium"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding BodyPreview}"
                                               FontSize="11" Foreground="#99FFFFFF"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TagsDisplay}"
                                           FontSize="10" Foreground="#66FFFFFF"
                                           VerticalAlignment="Top"
                                           Margin="8,2,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty / no-match states -->
            <StackPanel Grid.Row="2" Margin="12,4,12,12">
                <TextBlock Text="Geen snippets gevonden — bibliotheek is leeg."
                           FontSize="13" Foreground="#66FFFFFF"
                           HorizontalAlignment="Center" Margin="0,4"
                           Visibility="{Binding IsEmptyLibraryVisible, Converter={StaticResource BoolToVis}}"/>
                <TextBlock FontSize="13" Foreground="#66FFFFFF"
                           HorizontalAlignment="Center" Margin="0,4"
                           Visibility="{Binding IsNoMatchVisible, Converter={StaticResource BoolToVis}}">
                    <Run Text="Geen match — druk "/>
                    <Run Text="Enter" FontWeight="Bold" Foreground="#99FFFFFF"/>
                    <Run Text=" om snippet aan te maken met titel '"/>
                    <Run Text="{Binding QueryText}"/>
                    <Run Text="'"/>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</Window>
