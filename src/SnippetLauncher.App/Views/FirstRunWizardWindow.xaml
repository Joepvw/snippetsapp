<Window x:Class="SnippetLauncher.App.Views.FirstRunWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SnippetLauncher.App.ViewModels"
        Title="Snippet Launcher instellen"
        Width="560" Height="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True">

    <Window.Resources>
        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="Body" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Content area -->
        <Border Grid.Row="0" Padding="32,28,32,12">
            <Grid>
                <!-- Step 1: Welcome -->
                <StackPanel Visibility="{Binding IsWelcome, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource PageTitle}" Text="Welkom bij Snippet Launcher"/>
                    <TextBlock Style="{StaticResource Body}">
                        Snippet Launcher is een snelle, fuzzy-search popup voor je persoonlijke snippets-bibliotheek.
                        Je snippets worden opgeslagen als Markdown-bestanden in een Git-repository,
                        zodat je ze eenvoudig kunt synchroniseren met een tweede computer.
                    </TextBlock>
                    <TextBlock Style="{StaticResource Body}">
                        Deze wizard helpt je in 3 minuten op weg.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="📁  " FontSize="18"/>
                        <TextBlock Text="Lokale snippets-map kiezen" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="🔗  " FontSize="18"/>
                        <TextBlock Text="Optioneel: Git-remote koppelen voor sync" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="⌨️  " FontSize="18"/>
                        <TextBlock Text="Hotkeys bevestigen" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Step 2: Repo path -->
                <StackPanel Visibility="{Binding IsRepoPath, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource PageTitle}" Text="Snippets-map kiezen"/>
                    <TextBlock Style="{StaticResource Body}">
                        Kies een lege map of een bestaande Git-clone voor je snippets.
                        De app maakt hier een Git-repository aan als die er nog niet is.
                    </TextBlock>
                    <TextBlock Style="{StaticResource Label}" Text="Map"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding RepoPath, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,5" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="Bladeren…" Margin="6,0,0,0"
                                Command="{Binding BrowseFolderCommand}" Padding="10,5"/>
                    </Grid>
                </StackPanel>

                <!-- Step 3: Remote -->
                <StackPanel Visibility="{Binding IsRemote, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource PageTitle}" Text="Git-remote koppelen (optioneel)"/>
                    <TextBlock Style="{StaticResource Body}">
                        Voer de URL van je Git-remote in om snippets te synchroniseren met een tweede computer.
                        Je kunt dit ook later instellen via Instellingen → Opslag.
                    </TextBlock>
                    <TextBlock Style="{StaticResource Label}" Text="Remote URL"/>
                    <TextBox Text="{Binding RemoteUrl, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,5" VerticalContentAlignment="Center"
                             ToolTip="https://github.com/jouwnaam/snippets.git"/>
                    <TextBlock Margin="0,8,0,0" Foreground="#888" TextWrapping="Wrap" FontSize="12">
                        Authenticatie verloopt via Git Credential Manager (ingebouwd in Git for Windows).
                        Klik op "Volgende" om dit stap over te slaan.
                    </TextBlock>
                </StackPanel>

                <!-- Step 4: Hotkeys -->
                <StackPanel Visibility="{Binding IsHotkeys, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource PageTitle}" Text="Hotkeys instellen"/>
                    <TextBlock Style="{StaticResource Body}">
                        Dit zijn de standaard sneltoetsen. Je kunt ze later aanpassen via Instellingen.
                    </TextBlock>
                    <TextBlock Style="{StaticResource Label}" Text="Zoek-popup openen"/>
                    <TextBox Text="{Binding SearchHotkey, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,5" VerticalContentAlignment="Center"/>
                    <TextBlock Style="{StaticResource Label}" Text="Snel toevoegen vanuit klembord"/>
                    <TextBox Text="{Binding QuickAddHotkey, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6,5" VerticalContentAlignment="Center"/>
                    <TextBlock Margin="0,8,0,0" Foreground="#888" FontSize="12">
                        Formaat: Ctrl+Shift+Letter of Ctrl+Alt+F1 enz.
                    </TextBlock>
                </StackPanel>

                <!-- Step 5: Done -->
                <StackPanel Visibility="{Binding IsDone, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource PageTitle}" Text="Klaar! 🎉"/>
                    <TextBlock Style="{StaticResource Body}">
                        Snippet Launcher is ingesteld en klaar voor gebruik.
                    </TextBlock>
                    <TextBlock Style="{StaticResource Body}">
                        Druk op <Bold>Ctrl+Shift+Space</Bold> (of jouw gekozen combinatie) om de zoek-popup te openen.
                        De app blijft actief in de systeembalk.
                    </TextBlock>
                    <Border Background="#EBF5EB" CornerRadius="6" Padding="14,10" Margin="0,8,0,0">
                        <TextBlock TextWrapping="Wrap" Foreground="#2E7D32">
                            Tip: klik met rechts op het tray-icoon voor alle opties,
                            inclusief Snippets beheren en Instellingen.
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer: status + navigation -->
        <Grid Grid.Row="1" Margin="32,0,32,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Error / status message -->
            <TextBlock Grid.Row="0"
                       Text="{Binding StatusMessage}"
                       Foreground="#C62828"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>

            <!-- Buttons + step indicator -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="← Terug" Padding="12,6"
                        Command="{Binding BackCommand}"
                        Visibility="{Binding IsNotFirst, Converter={StaticResource BoolToVis}}"/>

                <!-- Step dots -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="3,0" Fill="{Binding IsWelcome,  Converter={StaticResource BoolToBrush}}"/>
                    <Ellipse Width="8" Height="8" Margin="3,0" Fill="{Binding IsRepoPath, Converter={StaticResource BoolToBrush}}"/>
                    <Ellipse Width="8" Height="8" Margin="3,0" Fill="{Binding IsRemote,   Converter={StaticResource BoolToBrush}}"/>
                    <Ellipse Width="8" Height="8" Margin="3,0" Fill="{Binding IsHotkeys,  Converter={StaticResource BoolToBrush}}"/>
                    <Ellipse Width="8" Height="8" Margin="3,0" Fill="{Binding IsDone,     Converter={StaticResource BoolToBrush}}"/>
                </StackPanel>

                <Button Grid.Column="3" Content="{Binding NextLabel}" Padding="14,6"
                        Command="{Binding NextCommand}"
                        Background="#1565C0" Foreground="White"
                        FontWeight="SemiBold"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
