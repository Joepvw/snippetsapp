<Window x:Class="SnippetLauncher.App.Views.PlaceholderFillDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vul waarden in"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="420"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="#FF1E1E2E">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,4,0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="Background" Value="#FF2A2A3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="20,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#FF4D9FFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">
        <TextBlock x:Name="TitleBlock"
                   FontSize="15" FontWeight="SemiBold"
                   Foreground="White" Margin="0,0,0,14"
                   TextWrapping="Wrap"/>

        <ItemsControl x:Name="FieldsPanel"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Annuleren" Click="Cancel_Click"
                    Background="#FF3A3A4E" Margin="0,0,8,0"/>
            <Button Content="OK" IsDefault="True" Click="OK_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
