<Window x:Class="SnippetLauncher.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Instellingen — Snippet Launcher"
        Width="520" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,3"/>
            <Setter Property="Foreground" Value="#444"/>
        </Style>
        <Style x:Key="ApplyBtn" TargetType="Button">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="16,12,16,0">

            <!-- Tab: Opslag -->
            <TabItem Header="Opslag">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Snippets-map"/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Pad naar Git-repository"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding RepoPath, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="6,5" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Content="Bladeren…"
                                    Command="{Binding BrowseRepoCommand}"
                                    Style="{StaticResource ApplyBtn}"/>
                            <Button Grid.Column="2" Content="Toepassen"
                                    Command="{Binding ApplyRepoPathCommand}"
                                    Style="{StaticResource ApplyBtn}"/>
                        </Grid>
                        <TextBlock Margin="0,4,0,0" Foreground="#888" FontSize="11" TextWrapping="Wrap">
                            Wijzigen herlaadt de volledige snippet-bibliotheek. Push-queue wordt eerst geleegd.
                        </TextBlock>

                        <TextBlock Style="{StaticResource SectionTitle}" Text="GitHub-remote"/>
                        <TextBlock Style="{StaticResource FieldLabel}" Text="HTTPS-URL van de gedeelde repository"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding RemoteUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="6,5" VerticalContentAlignment="Center"
                                     ToolTip="https://github.com/jouwnaam/snippets.git"/>
                            <Button Grid.Column="1" Content="Toepassen"
                                    Command="{Binding ApplyRemoteUrlCommand}"
                                    Style="{StaticResource ApplyBtn}"/>
                        </Grid>
                        <TextBlock Margin="0,4,0,0" Foreground="#888" FontSize="11" TextWrapping="Wrap">
                            Leeg laten om sync uit te schakelen. Authenticatie verloopt via Git Credential Manager.
                        </TextBlock>

                        <TextBlock Style="{StaticResource SectionTitle}" Text="Synchronisatie"/>
                        <Button Content="Nu synchroniseren (haal op + verstuur)"
                                Command="{Binding SyncNowCommand}"
                                HorizontalAlignment="Left" Padding="14,6"/>
                        <TextBlock Margin="0,4,0,0" Foreground="#888" FontSize="11" TextWrapping="Wrap">
                            Forceer een directe pull en push. Handig na het instellen van de remote-URL.
                        </TextBlock>

                        <TextBlock Style="{StaticResource SectionTitle}" Text="Sync-interval"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox Width="70"
                                     Text="{Binding PullIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="6,5" VerticalContentAlignment="Center"/>
                            <TextBlock Text="seconden" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            <Button Content="Toepassen" Command="{Binding ApplyPullIntervalCommand}"
                                    Style="{StaticResource ApplyBtn}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab: Hotkeys -->
            <TabItem Header="Sneltoetsen">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Globale sneltoetsen"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,8">
                            Formaat: Ctrl+Shift+Letter, Ctrl+Alt+F1, enz.
                            Wijzigingen worden direct toegepast; bij conflict wordt de oude waarde hersteld.
                        </TextBlock>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Zoek-popup openen"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding SearchHotkey, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="6,5" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Content="Toepassen"
                                    Command="{Binding ApplySearchHotkeyCommand}"
                                    Style="{StaticResource ApplyBtn}"/>
                        </Grid>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="Snel toevoegen vanuit klembord"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding QuickAddHotkey, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="6,5" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Content="Toepassen"
                                    Command="{Binding ApplyQuickAddHotkeyCommand}"
                                    Style="{StaticResource ApplyBtn}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab: Systeem -->
            <TabItem Header="Systeem">
                <StackPanel Margin="4,0">
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Opstarten"/>
                    <CheckBox Content="Automatisch starten bij Windows-login"
                              IsChecked="{Binding StartAtLoginEnabled}"
                              Margin="0,8,0,0"/>
                    <TextBlock Margin="0,6,0,0" Foreground="#888" FontSize="11" TextWrapping="Wrap">
                        Snippet Launcher start automatisch zodra je inlogt op Windows en blijft in het systeemvak draaien.
                    </TextBlock>
                </StackPanel>
            </TabItem>

            <!-- Tab: Weergave -->
            <TabItem Header="Weergave">
                <StackPanel Margin="4,0">
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Thema"/>
                    <StackPanel Orientation="Horizontal">
                        <ComboBox ItemsSource="{Binding Themes}"
                                  SelectedItem="{Binding SelectedTheme}"
                                  Width="140"/>
                        <Button Content="Toepassen" Command="{Binding ApplyThemeCommand}"
                                Style="{StaticResource ApplyBtn}"/>
                    </StackPanel>
                    <TextBlock Margin="0,6,0,0" Foreground="#888" FontSize="11">
                        Themawijzigingen zijn na herstart van de app van kracht.
                    </TextBlock>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="1" Padding="20,8" BorderThickness="0,1,0,0"
                BorderBrush="#DDD" Background="#FAFAFA">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           Foreground="{Binding HasError, Converter={StaticResource BoolToErrorBrush}}"
                           TextWrapping="Wrap"/>
                <TextBlock Grid.Column="1" Text="{Binding AppVersion}"
                           Foreground="#999" FontSize="11" Margin="12,0,0,0"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
